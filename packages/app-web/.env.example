# ── app-web environment variables ──────────────────────────────────────────
#
# Copy this file to .env and fill in values:
#   cp .env.example .env
#
# For hosted builds, set these as build-time environment variables.

# Required — exact http(s) Relay API URL (Host origin + /relay).
# Credentials, query strings, fragments, and other paths are rejected.
# Network is auto-detected from the Host via GET /relay/config.
VITE_STELIS_RELAY_API_URL=http://localhost:3200/relay

# Optional — UI mode (relay | studio). Default: relay. Other values fail the build.
# 'relay' = public pages for Status, Docs, Playground, and Sandbox
# 'studio' = adds /promotion route for studio AuthJwt testing
# VITE_STELIS_UI_MODE=relay

# Optional — http(s) repository docs base URL used by Docs page deep links.
# Credentials, query strings, and fragments are rejected.
# If omitted, the Docs page hides GitHub source links.
VITE_REPO_DOCS_BASE_URL=https://github.com/stelis-dev/stelis/blob/main
