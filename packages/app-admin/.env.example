# ── app-admin local environment ────────────────────────────────────────
#
# Copy this file and fill in values if needed:
#   cp .env.example .env
#
# For production deployment, set these as environment variables in the hosting platform.

# Required — app-api endpoint URL.
# Used by Vite dev proxy (/auth, /api, /relay, /studio, /health) and production explicit-base routing.
# Network is auto-detected from the Host via GET /relay/config.
VITE_STELIS_API_URL=http://localhost:3200
