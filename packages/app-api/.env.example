# ── app-api local environment ──────────────────────────────────────────
#
# Copy this file and fill in real values:
#   cp .env.example .env
#
# This file is for local `@stelis/app-api` development.
# Deployed hosts should receive environment values from the deployment platform.

# ── Required ──────────────────────────────────────────────────────────

# `npm run dev:app-api` starts an isolated Redis memory server and sets
# REDIS_URL for the child process. Do not set REDIS_URL for local dev; if
# REDIS_URL is present in the shell or this file, the root dev helper
# overwrites it.
# Deployed hosts must receive REDIS_URL from the deployment environment.

# Sponsor keypair(s) (Bech32). Gas sponsor for user transactions.
# Multiple keys: comma-separated for pool concurrency.
#   e.g. suiprivkey1aaa...,suiprivkey1bbb...
SPONSOR_SECRET_KEY=suiprivkey1...

# Sponsor Refill Account keypair (Bech32). Must differ from SPONSOR_SECRET_KEY.
# Signs refill transactions from operational capital and admin withdrawals.
SPONSOR_REFILL_ACCOUNT_SECRET_KEY=suiprivkey1...

# Network: testnet or mainnet
NETWORK=testnet

# Fee revenue recipient address (no private key held by system)
SETTLEMENT_PAYOUT_RECIPIENT_ADDRESS=0x...

# Sponsor slot lease HMAC secret (≥32 chars).
# The sponsor pool stores HMAC(secret, receiptId || slotId) as its lease
# proof and verifies it on sign/checkin. This secret must live in process
# env only — never in Redis, never in the prepare store, never logged.
# The value below is a local placeholder. Generate a real value for any
# shared or deployed host, e.g. `openssl rand -base64 48`.
SPONSOR_LEASE_HMAC_SECRET=local-dev-sponsor-lease-hmac-secret-change-me

# ── Optional (admin dashboard) ────────────────────────────────────────

# Admin wallet address for dashboard login (0x + 64 hex)
# ADMIN_ADDRESS=0x...

# Admin JWT secret (≥32 chars). Required if ADMIN_ADDRESS is set.
# Used by /auth routes for session JWT signing.
# ADMIN_JWT_SECRET=

# Admin session duration (default: 1h)
# ADMIN_SESSION_EXPIRY=1h

# Cookie domain for cross-subdomain auth (e.g. admin.example.com ↔ api.example.com).
# Set to the shared parent domain with leading dot (e.g. ".example.com").
# When set, cookies use SameSite=Lax + Domain. When unset, SameSite=Strict (same-origin).
# COOKIE_DOMAIN=.example.com

# ── Optional (studio auto-detect) ────────────────────────────────────
# Set ALL 4 keys to enable studio mode:
#   - ADMIN_JWT_SECRET
#   - ADMIN_ADDRESS
#   - STUDIO_ALLOWED_TARGETS
#   - STUDIO_DEVELOPER_JWT_TRUST_JSON

# Global MoveCall target allowlist (required in studio mode).
# Comma-separated pkg::mod::fn entries. Every MoveCall in sponsored PTBs
# must match an entry in this list (R-10 enforcement via sha256 hash).
# STUDIO_ALLOWED_TARGETS=0xPKG::module::function,0xPKG2::mod2::fn2

# Developer JWT trust config (required in studio mode).
# Single issuer object: issuer, audience, algorithm (RS256|ES256), publicKeyPem, claimPaths.
# Stelis verifies developer JWTs locally using this trust material.
# STUDIO_DEVELOPER_JWT_TRUST_JSON={"issuer":"https://auth.example.com","audience":"stelis-studio","algorithm":"RS256","publicKeyPem":"-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----","claimPaths":{"userId":"sub","senderAddress":"wallet_address"}}

# Optional developer-side JWT validity callback URL.
# When configured, Stelis calls this URL after local verification to confirm
# the developer JWT is still valid (e.g., not revoked). Fail-closed on error.
# STUDIO_DEVELOPER_JWT_VERIFY_URL=https://auth.example.com/verify

# ── Optional ──────────────────────────────────────────────────────────

# HTTP server port. Defaults to 3200 when unset.
# PORT=3200

# Runtime mode. Local development uses development.
NODE_ENV=development

# Number of trusted reverse proxy hops for client IP extraction.
# Local development normally runs app-api directly, so this is 0.
TRUSTED_PROXY_HOPS=0

# CORS origins (comma-separated). Usually unnecessary for Vite local dev
# because app-web and app-admin proxy requests to app-api.
# Set this when a browser calls admin/auth routes directly from these origins.
# CORS_ORIGINS=http://localhost:5173,http://localhost:3100

# ── Required (sponsor-operations tuning) ────────────────────────────────────
#
# All four SPONSOR_OPERATIONS_*_MS variables are required at boot and have no
# code-side default. Pick deploy-time values consistent with the
# description for each row. Each value must be a positive integer number
# of milliseconds; boot fails closed if missing or invalid.

# Per-slot `getBalance` read timeout during bootstrap sync and sponsor
# result state updates. On timeout the slot is written as `rpc_unreachable`
# in the shared sponsor operations state.
SPONSOR_OPERATIONS_SLOT_BALANCE_TIMEOUT_MS=5000

# Sponsor Refill Account `getBalance` read timeout. Shared by bootstrap sync,
# the refill-success account probe, the admin `/api/pool` bounded probe, and
# the sponsor-success account probe when the settlement payout recipient is the Sponsor
# Refill Account.
# On timeout `sponsorRefillAccount.healthy = false` is written.
SPONSOR_OPERATIONS_SPONSOR_REFILL_ACCOUNT_BALANCE_TIMEOUT_MS=5000

# Upper bound for a single refill transaction dispatch. On timeout the
# target slot becomes `refill_failed` and the refill worker is freed.
SPONSOR_OPERATIONS_REFILL_TIMEOUT_MS=30000

# Upper bound for the `awaiting_confirmation` phase after a successful
# refill dispatch. On timeout the slot becomes `refill_failed`.
SPONSOR_OPERATIONS_CONFIRMATION_TIMEOUT_MS=15000

# ── Optional (sponsor pool tuning) ────────────────────────────────────

# Low-balance warning threshold in MIST (default: 5000000000 = 5 SUI).
# Must be a positive integer > 0 when set. Boot fails if invalid.
# Slots below this are written as `low_balance` in the shared sponsor-
# operations state; when every slot is degraded (`availableSlots === 0`), the
# route gate returns `503 SPONSOR_CAPACITY_UNAVAILABLE`.
# SPONSOR_BALANCE_WARN_MIST=5000000000

# Automatic refill is disabled when this variable is unset.
# Set to true to refill low-balance sponsor slots from the Sponsor Refill Account.
# SPONSOR_OPERATIONS_REFILL_ENABLED=true

# Target balance for automatic refill in MIST (example: 10000000000 = 10 SUI).
# Required when automatic refill is enabled.
# Must be a positive integer > 0 and strictly greater than SPONSOR_BALANCE_WARN_MIST.
# SPONSOR_BALANCE_REFILL_TARGET_MIST=10000000000

# ── Optional (relay fee) ──────────────────────────────────────────────

# Host fee quoted to clients in MIST (default: 0 = 0 SUI).
# Non-negative integer.
# Set to 0 or remove to disable the host fee.
# HOST_FEE_MIST=0
