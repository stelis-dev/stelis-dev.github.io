{
    "name": "@stelis/contracts",
    "version": "0.1.0",
    "private": true,
    "description": "Stelis shared TypeScript contract data, request and response types, runtime constants, and pure lookups for cross-package boundaries.",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "node ../../scripts/clean-package-dist.mjs && tsc",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "typescript": "^5.4.0"
    },
    "files": [
        "dist"
    ],
    "license": "MIT"
}
