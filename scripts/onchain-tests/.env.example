# Local-only on-chain test environment.
# Copy to scripts/onchain-tests/.env and fill values locally.
# Never commit scripts/onchain-tests/.env.

# Current testnet Host Relay API URL. Include or omit the trailing /relay; the
# script normalizes it. Do not use the temporary demo deployment as a durable
# benchmark target.
STELIS_ONCHAIN_RELAY_API_URL=

# Test wallet secret key in Sui Bech32 format. This wallet should be disposable.
STELIS_ONCHAIN_USER_SECRET_KEY=

# Exact settlement token type copied from the current Host /relay/config.
# Symbols are display labels and are never accepted as token identity.
STELIS_ONCHAIN_SETTLEMENT_TOKEN_TYPE=

# sponsored: run Host-sponsored empty user PTBs until current Host funding
# policy rejects the wallet or max runs is hit.
# direct: run direct empty SUI PTBs until reserve + gas budget cannot be kept.
# both: run sponsored first, then direct. The wallet must already hold the direct
# reserve + gas budget when the process starts; there is no mid-run funding pause.
STELIS_ONCHAIN_PHASE=sponsored

# Independent verified-success caps. Keep these small until the test wallet and
# Host config are confirmed.
STELIS_ONCHAIN_SPONSORED_MAX_RUNS=20
STELIS_ONCHAIN_DIRECT_MAX_RUNS=20

# Sponsored prepare slippage tolerance in basis points. Default: 200; max: 500.
STELIS_ONCHAIN_SLIPPAGE_BPS=200

# Optional isolation check. When true, sponsored runs require the test wallet to
# hold exactly zero SUI before each submission. Default: false.
STELIS_ONCHAIN_REQUIRE_ZERO_SUI_FOR_SPONSORED=false

# Direct empty-transaction gas budget in MIST.
STELIS_ONCHAIN_DIRECT_GAS_BUDGET_MIST=3000000

# Preserve at least this much SUI after one full direct gas budget.
STELIS_ONCHAIN_MIN_SUI_RESERVE_MIST=0

# Optional: custom gRPC endpoint. Defaults to the official Sui testnet endpoint.
# STELIS_ONCHAIN_GRPC_URL=https://fullnode.testnet.sui.io:443

# Raw JSONL files are timestamped and accumulated under this ignored directory.
STELIS_ONCHAIN_RAW_DIR=.WORK/onchain-tests/raw

# Generated Markdown reports are timestamped and kept in the ignored work area.
# Copy only deliberately reviewed evidence into docs/onchain-tests/reports.
STELIS_ONCHAIN_REPORT_DIR=.WORK/onchain-tests/reports
