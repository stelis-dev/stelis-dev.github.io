# Local-only on-chain test environment.
# Copy to scripts/onchain-tests/.env and fill values locally.
# Never commit scripts/onchain-tests/.env.

# Relay API base URL. Include or omit the trailing /relay; the script normalizes it.
STELIS_ONCHAIN_RELAY_API_URL=https://stelis-api.vercel.app/relay

# Test wallet secret key in Sui Bech32 format. This wallet should be disposable.
STELIS_ONCHAIN_USER_SECRET_KEY=

# Pick one settlement token from /relay/config.
# Prefer symbol for local test convenience. Use full type if multiple paths share a symbol.
STELIS_ONCHAIN_SETTLEMENT_TOKEN_SYMBOL=DEEP
# STELIS_ONCHAIN_SETTLEMENT_TOKEN_TYPE=

# sponsored: run Host-sponsored empty user PTBs until the token is exhausted or max runs is hit.
# direct: run direct empty SUI PTBs until SUI is exhausted or max runs is hit.
# both: run sponsored first, then direct. Fund SUI before direct if needed.
STELIS_ONCHAIN_PHASE=sponsored

# Run cap for each selected phase. Keep this small until the test wallet and Host config are confirmed.
STELIS_ONCHAIN_MAX_RUNS=20

# Stop the sponsored phase when the raw settlement-token balance is at or below
# this value. Default: 0.
STELIS_ONCHAIN_MIN_SETTLEMENT_TOKEN_RAW=0

# Sponsored prepare slippage tolerance in basis points. Default: 200; max: 500.
STELIS_ONCHAIN_SLIPPAGE_BPS=200

# Optional isolation check. When true, sponsored runs require the test wallet to
# hold exactly zero SUI before each submission. Default: false.
STELIS_ONCHAIN_REQUIRE_ZERO_SUI_FOR_SPONSORED=false

# Direct empty-transaction gas budget in MIST.
STELIS_ONCHAIN_DIRECT_GAS_BUDGET_MIST=3000000

# Optional: stop the direct phase when SUI balance is at or below this reserve.
STELIS_ONCHAIN_MIN_SUI_RESERVE_MIST=0

# Optional: custom gRPC endpoint. Defaults from /relay/config network.
# STELIS_ONCHAIN_GRPC_URL=https://fullnode.testnet.sui.io:443

# Raw JSONL files are timestamped and accumulated under this ignored directory.
STELIS_ONCHAIN_RAW_DIR=.WORK/onchain-tests/raw

# Processed Markdown reports are appended to fixed test report files under docs.
STELIS_ONCHAIN_REPORT_DIR=docs/onchain-tests/reports
